# =============================================================================
# OpenRSVP Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.

# Server
PORT=8080
ENV=development
# ENV=production

# Database
DB_DRIVER=sqlite
DB_DSN=/data/openrsvp.db
# For PostgreSQL:
# DB_DRIVER=postgres
# DB_DSN=postgres://user:pass@localhost:5432/openrsvp?sslmode=disable

# Auth
MAGIC_LINK_EXPIRY=15m
SESSION_EXPIRY=168h
BASE_URL=http://localhost:8080

# Email Notifications
# Provider: smtp, sendgrid, ses
NOTIFICATION_EMAIL_PROVIDER=smtp

# SMTP settings (used when provider=smtp)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@openrsvp.local

# SendGrid settings (used when provider=sendgrid)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM=noreply@yourdomain.com

# AWS SES settings (used when provider=ses)
# SES_REGION=us-east-1
# SES_USERNAME=your-ses-smtp-username
# SES_PASSWORD=your-ses-smtp-password
# SES_FROM=noreply@yourdomain.com

# SMS Notifications (optional)
# Provider: twilio, vonage, sns
# NOTIFICATION_SMS_PROVIDER=twilio

# Twilio settings
# TWILIO_ACCOUNT_SID=ACxxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_FROM_NUMBER=+15551234567

# Vonage settings
# VONAGE_API_KEY=xxxxx
# VONAGE_API_SECRET=xxxxx
# VONAGE_FROM=OpenRSVP

# Amazon SNS settings (used when provider=sns)
# SNS_SMS_REGION=us-east-1
# SNS_SMS_ACCESS_KEY_ID=AKIAxxxxx
# SNS_SMS_SECRET_ACCESS_KEY=xxxxx

# Data Retention
DEFAULT_RETENTION_DAYS=30
